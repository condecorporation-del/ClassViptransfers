{
  "name": "los-cabos-luxe-transfers-backend",
  "version": "1.0.0",
  "description": "Backend API for Los Cabos Luxe Transfers booking system",
  "main": "dist/server.js",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prebuild": "node -e \"const fs=require('fs'); if(!fs.existsSync('src/server.ts')) { console.error('ERROR: src/server.ts not found. Make sure backend/src/ is tracked in git.'); process.exit(1); } console.log('✅ src/server.ts found');\"",
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs'); if(!fs.existsSync('dist/server.js')) { console.error('ERROR: Missing dist/server.js'); process.exit(1); } console.log('✅ dist/server.js exists');\"",
    "start": "node dist/server.js",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:test": "tsx scripts/test-connection.ts",
    "verify:env": "tsx scripts/verificar-env.ts",
    "generate-sitemap": "tsx scripts/generate-sitemap.ts",
    "setup:supabase": "tsx scripts/auto-setup-supabase.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.16.5",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^8.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "openai": "^6.22.0",
    "prisma": "^5.20.0",
    "puppeteer": "^24.37.5",
    "resend": "^6.9.2",
    "stripe": "^21.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
