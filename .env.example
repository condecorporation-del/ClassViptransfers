# Frontend environment variables
# Copy to .env.local for local frontend development if needed.

# Public Stripe key used by the checkout page
VITE_STRIPE_PUBLIC_KEY=pk_test_your_public_key_here

# Optional production API base URL.
# In local development the frontend uses the Vite proxy, so this can stay empty.
VITE_API_BASE_URL=

# Optional build metadata shown in the footer
VITE_COMMIT_REF=local
VITE_CONTEXT=local

# Optional Cloudinary reference used by local asset scripts only
CLOUDINARY_CLOUD_NAME=dt9iyiorn
