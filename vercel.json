{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/favicon.ico", "destination": "/favicon.png", "permanent": false },
    { "source": "/transfers/", "destination": "/", "permanent": true },
    { "source": "/san-jose-del-cabo", "destination": "/", "permanent": true },
    { "source": "/san-jose-del-cabo/", "destination": "/", "permanent": true },
    { "source": "/cabo-san-lucas", "destination": "/", "permanent": true },
    { "source": "/cabo-san-lucas/", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
