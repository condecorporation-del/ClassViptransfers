{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/transfers/", "destination": "/", "permanent": true },
    { "source": "/san-jose-del-cabo", "destination": "/", "permanent": true },
    { "source": "/san-jose-del-cabo/", "destination": "/", "permanent": true },
    { "source": "/cabo-san-lucas", "destination": "/", "permanent": true },
    { "source": "/cabo-san-lucas/", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
