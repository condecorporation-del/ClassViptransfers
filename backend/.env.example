# =========================
# Core app
# =========================
NODE_ENV=development
PORT=3001

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://127.0.0.1:5174,http://localhost:5174
FRONTEND_PREVIEW_URLS=
ALLOW_VERCEL_PREVIEW_ORIGINS=false

# Public app URLs
FRONTEND_URL=http://127.0.0.1:5174
BACKEND_URL=http://127.0.0.1:3001


# =========================
# Database
# =========================
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres


# =========================
# Admin auth
# =========================
ADMIN_EMAIL=admin@example.com
# Generate a bcrypt hash, not a plain password
ADMIN_PASSWORD_HASH=
ADMIN_JWT_SECRET=
ADMIN_AUTH_DISABLED=false


# =========================
# Booking / secure links
# =========================
JWT_SECRET=
BOOKING_LOOKUP_SECRET=
BOOKING_PDF_SECRET=


# =========================
# Stripe
# =========================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# =========================
# Email / notifications
# =========================
COMPANY_BOOKINGS_EMAIL=
EMAIL_COMPANY_TO=
EMAIL_FROM=Class VIP Transfers <reservations@example.com>
EMAIL_TEST_TO=

# Gmail SMTP option
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Resend option
RESEND_API_KEY=


# =========================
# Email branding
# =========================
EMAIL_LOGO_URL=
EMAIL_WATERMARK_LOGO_URL=
EMAIL_BRAND_NAME=Class VIP Transfers
EMAIL_PRIMARY_COLOR=#071A2B
EMAIL_ACCENT_COLOR=#D9AE5F
EMAIL_BG_COLOR=#F7FAFF


# =========================
# AI
# =========================
OPENAI_API_KEY=
